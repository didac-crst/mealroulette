# Database
POSTGRES_USER=mealroulette
POSTGRES_PASSWORD=mealroulette
POSTGRES_DB=mealroulette
DATABASE_URL=postgresql+psycopg://mealroulette:mealroulette@db:5432/mealroulette

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
# Required for JWT signing. Generate a strong value (32+ bytes), e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Do not use placeholder strings such as change-me-in-production.
SECRET_KEY=
# Telegram bot token from BotFather (not stored in DB; used by API + worker)
TELEGRAM_BOT_TOKEN=
# Optional: bot username without @ (used for recipe links in planning messages)
TELEGRAM_BOT_USERNAME=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend API URL override (usually leave empty).
# By default the browser calls /api on the same host as the UI; Vite proxies to the backend.
# Set only when the API is on a different host (unusual for local Docker Compose).
VITE_API_URL=

# Test database (local/CI)
TEST_DATABASE_URL=postgresql+psycopg://mealroulette:mealroulette@localhost:5432/mealroulette_test
